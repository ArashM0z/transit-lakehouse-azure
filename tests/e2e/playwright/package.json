{
  "name": "transit-lakehouse-e2e",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=ui-chromium",
    "test:all-browsers": "playwright test --project=ui-chromium --project=ui-firefox --project=ui-webkit",
    "report": "playwright show-report ../../../target/playwright-report",
    "codegen": "playwright codegen http://localhost:8000"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
