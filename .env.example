# Copy to .env and fill in. The .env file is gitignored.

# Azure (production deploys)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Databricks workspace (set by Terraform output for production)
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# Local development — defaults that work with docker-compose
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lakehouse

KAFKA_BOOTSTRAP=redpanda:9092
KAFKA_TOPIC_AFC_TAPS=afc.taps
KAFKA_TOPIC_GTFS_RT=gtfs.realtime

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lakehouse
POSTGRES_USER=lakehouse
POSTGRES_PASSWORD=lakehouse

MLFLOW_TRACKING_URI=http://mlflow:5000

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=transit-lakehouse
 # Most code paths assume America/Toronto. The Docker images set TZ explicitly.

# set TZ=America/Toronto so timestamps stay consistent locally
