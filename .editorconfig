root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml,json,tf,tfvars,hcl}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{js,jsx,ts,tsx,vue,html,css,scss}]
indent_size = 2

# end of .editorconfig
